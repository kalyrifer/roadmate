# RoadMate Backend Configuration
# ===============================
# Пример конфигурационного файла. Скопируйте в .env и настройте под ваше окружение.

# ============================================
# НАСТРОЙКИ ПРИЛОЖЕНИЯ (APP)
# ============================================
APP_NAME=RoadMate
APP_VERSION=0.1.0
APP_DESCRIPTION=BlaBlaCar clone - сервис для поиска попутчиков

# Режим работы: dev, test, prod
APP_DEBUG=true
APP_ENVIRONMENT=dev
APP_TESTING=false

# API настройки
APP_API_V1_PREFIX=/api/v1
APP_API_DOCS_URL=/docs
APP_API_REDOC_URL=/redoc

# Сервер
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

# ============================================
# БАЗА ДАННЫХ (DATABASE)
# ============================================
# Асинхронный URL для SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://roadmate:roadmate_pass@localhost:5432/roadmate_db

# Синхронный URL для Alembic миграций
DATABASE_URL_SYNC=postgresql://roadmate:roadmate_pass@localhost:5432/roadmate_db

# Пул соединений
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Отладка SQL
DATABASE_ECHO=false

# ============================================
# JWT ТОКЕНЫ (JWT)
# ============================================
# ВАЖНО: Измените в production!
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT payload настройки
JWT_SUBJECT=access
# JWT_AUDIENCE=roadmate-api
# JWT_ISSUER=roadmate

# ============================================
# БЕЗОПАСНОСТЬ (SECURITY)
# ============================================
# Дублируется для совместимости с security.py
SECURITY_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET_KEY
SECURITY_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=7

# Bcrypt
SECURITY_BCRYPT_ROUNDS=12

# OAuth2
SECURITY_OAUTH2_PROVIDER=jwt
SECURITY_OAUTH2_TOKEN_URL=/api/v1/auth/login

# CORS (продублировано для удобства)
SECURITY_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
SECURITY_CORS_ALLOW_CREDENTIALS=true
SECURITY_CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
SECURITY_CORS_ALLOW_HEADERS=["*"]

# Rate limiting
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_PER_MINUTE=60
SECURITY_RATE_LIMIT_PER_HOUR=1000

# ============================================
# CORS (отдельная категория)
# ============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# ============================================
# ФАЙЛЫ (FILES)
# ============================================
FILES_UPLOAD_DIR=./uploads
FILES_MAX_FILE_SIZE=10485760

# Разрешённые типы файлов
FILES_ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/gif","image/webp"]
FILES_ALLOWED_DOCUMENT_TYPES=["application/pdf","application/msword","application/vnd.openxmlformats-officedocument.wordprocessingml.document"]

# S3 настройки (опционально)
FILES_S3_ENABLED=false
FILES_S3_BUCKET_NAME=roadmate-files
FILES_S3_REGION=us-east-1
# FILES_S3_ACCESS_KEY_ID=
# FILES_S3_SECRET_ACCESS_KEY=
# FILES_S3_ENDPOINT_URL=

# ============================================
# ЛОКАЛИЗАЦИЯ (LOCALE)
# ============================================
LOCALE_DEFAULT_LANGUAGE=ru
LOCALE_SUPPORTED_LANGUAGES=["ru","en"]

# Переводы
LOCALE_TRANSLATIONS_PROVIDER=json
LOCALE_TRANSLATIONS_DIR=./app/locales

# Форматы
LOCALE_DATE_FORMAT=%d.%m.%Y
LOCALE_DATETIME_FORMAT=%d.%m.%Y %H:%M
LOCALE_TIMEZONE=Europe/Moscow

# ============================================
# ЛОГИРОВАНИЕ (LOG)
# ============================================
LOG_LOG_LEVEL=INFO
LOG_LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Консоль
LOG_CONSOLE_ENABLED=true
# LOG_CONSOLE_FORMAT=

# Файл
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# JSON логирование
LOG_JSON_ENABLED=false

# SQL логирование
LOG_SQL_ALCHEMY=false
LOG_SQL_ECHO=false
