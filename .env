# Environment variables for RoadMate
# Скопируйте этот файл в .env и настройте под ваше окружение

# =====================
# Database (PostgreSQL)
# =====================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/roadmate2
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/roadmate2
DATABASE_ECHO=false

# =====================
# Security & JWT
# =====================
SECRET_KEY=postgres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =====================
# CORS
# =====================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000"]
CORS_ALLOW_CREDENTIALS=true

# =====================
# App Settings
# =====================
DEBUG=true
APP_ENVIRONMENT=dev

# =====================
# Files
# =====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# =====================
# Locale
# =====================
DEFAULT_LANGUAGE=ru
SUPPORTED_LANGUAGES=["ru","en"]

# =====================
# Logging
# =====================
LOG_LEVEL=INFO